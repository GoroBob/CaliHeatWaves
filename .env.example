# CaliHeatWaves Environment Configuration
# Copy this to .env and fill in your values

# CDS API (for ERA5 data downloads)
# Get credentials from: https://cds.climate.copernicus.eu/
CDSAPI_URL=https://cds.climate.copernicus.eu/api/v2
CDSAPI_KEY=

# Data paths (optional - modify if needed)
DATA_RAW_DIR=shared/data/raw
DATA_INTERIM_DIR=shared/data/interim
DATA_PROCESSED_DIR=shared/data/processed

# Geographic data
GEO_DIR=shared/geography

# Jupyter settings
JUPYTER_TOKEN=
